{
  "name": "store-support-agent",
  "version": "1.0.0",
  "description": "Tool-Using Support Agent with Persistent Memory for Store Management",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node --transpileOnly src/cli.ts",
    "dev:ui": "ts-node --transpileOnly src/server.ts",
    "eval": "ts-node --transpileOnly src/eval/runner.ts",
    "db:migrate": "ts-node --transpileOnly src/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "ai": "^6.0.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "pg": "^8.13.3",
    "readline": "^1.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
